<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B3E"
    android:orientation="vertical">

    <!-- 상단 헤더 -->
    <TextView
        android:id="@+id/tvReportTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        android:text="상세 건강 리포트"
        android:textColor="#4FC3F7"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- 본문 내용 스크롤 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:scrollbarSize="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 1. 최근 측정 결과 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1A237E"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvReportSubTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="최근 측정 수치"
                    android:textColor="#90CAF9"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvReportValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#4FC3F7"
                    android:textSize="38sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvReportStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● 정상"
                    android:textColor="#69F0AE"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- 2. 정밀 상태 분석 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1A237E"
                android:orientation="vertical"
                android:padding="18dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📝 정밀 상태 분석"
                    android:textColor="#4FC3F7"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvDetailedAnalysis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="수치 분석 내용 로드 중..."
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:lineSpacingExtra="5dp" />

            </LinearLayout>

            <!-- 3. 맞춤 추천 식단 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1A237E"
                android:orientation="vertical"
                android:padding="18dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🥗 추천 건강 식단"
                    android:textColor="#FFA726"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvDietRecommendation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="추천 식단 로드 중..."
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:lineSpacingExtra="5dp" />

            </LinearLayout>

            <!-- 4. 맞춤 추천 영양제 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1A237E"
                android:orientation="vertical"
                android:padding="18dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💊 추천 맞춤 영양제"
                    android:textColor="#69F0AE"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvSupplementsRecommendation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="추천 영양제 로드 중..."
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:lineSpacingExtra="5dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- 하단 복귀 버튼 -->
    <Button
        android:id="@+id/btnReportToSelect"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="16dp"
        android:text="측정 항목 선택으로 돌아가기"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#1565C0" />

</LinearLayout>
