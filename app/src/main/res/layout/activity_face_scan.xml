<?xml version="1.0" encoding="utf-8"?>
<!--
    페이스 스캐닝 레이아웃
    기술스택: FrameLayout (카메라+스캔바 겹치기), RadioButton (앞면/측면),
              TextView, LinearLayout, TableLayout (버튼 2열)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B3E"
    android:orientation="vertical">

    <!-- 상단 제목 + 단계 표시 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/tvFaceScanTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="얼굴 인식 스캔"
            android:textColor="#4FC3F7"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStepIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="1 / 4"
            android:textColor="#90CAF9"
            android:textSize="14sp" />
    </RelativeLayout>

    <!-- ============================================================
         RadioButton: 앞면/측면 선택
         기술스택: RadioButton, LinearLayout
    ============================================================ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="12dp">

        <RadioGroup
            android:id="@+id/rgScanMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbFront"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="정면"
                android:textColor="#FFFFFF"
                android:buttonTint="#4FC3F7"
                android:checked="true"
                android:layout_marginEnd="24dp"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/rbSide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="측면"
                android:textColor="#FFFFFF"
                android:buttonTint="#4FC3F7"
                android:textSize="15sp" />

        </RadioGroup>
    </LinearLayout>

    <!-- ============================================================
         FrameLayout: 카메라 미리보기 + 스캔 레이저 바 겹치기
         기술스택: FrameLayout
    ============================================================ -->
    <FrameLayout
        android:layout_width="240dp"
        android:layout_height="280dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp">

        <!-- 실사 이미지 영역 -->
        <ImageView
            android:id="@+id/ivFacePreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/front_face"
            android:contentDescription="얼굴 미리보기" />

        <!-- 카메라 미리보기 영역 (타원 가이드) -->
        <ImageView
            android:id="@+id/ivFaceGuide"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/face_oval_bg"
            android:contentDescription="얼굴 가이드" />

        <!-- 스캔 레이저 바 (위아래 애니메이션) -->
        <View
            android:id="@+id/vScanBar"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="#00E5FF"
            android:alpha="1.0"
            android:elevation="10dp" />

        <!-- "Face Guide" 텍스트 오버레이 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="12dp"
            android:text="얼굴을 원 안에 맞춰주세요"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="#55000000"
            android:padding="6dp" />

    </FrameLayout>

    <!-- ============================================================
         진행 상태 + 퍼센트
         기술스택: TextView
    ============================================================ -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/tvScanStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="분석 중..."
            android:textColor="#4FC3F7"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvScanPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="45%"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- 진행 바 -->
    <ProgressBar
        android:id="@+id/progressScan"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:progress="45"
        android:progressTint="#4FC3F7"
        android:progressBackgroundTint="#1A237E" />

    <!-- 공간 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- ============================================================
         하단 버튼 2개 (완료 / 재시도)
         기술스택: TableLayout (1행 2열)
    ============================================================ -->
    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:padding="16dp"
        android:stretchColumns="*">

        <TableRow>

            <Button
                android:id="@+id/btnRetry"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="재시도"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1565C0"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnScanComplete"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="완료"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4FC3F7"
                android:textSize="16sp" />

        </TableRow>
    </TableLayout>

</LinearLayout>
