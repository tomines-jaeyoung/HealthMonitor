<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_blue">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:text="산소포화도 측정"
        android:textColor="#4FC3F7"
        android:textSize="22sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvSpO2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--.-%%" 
            android:textColor="#4FC3F7"
            android:textSize="72sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SpO₂"
            android:textColor="#90CAF9"
            android:textSize="20sp"
            android:layout_marginBottom="24dp" />

        <ProgressBar
            android:id="@+id/gaugeBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:layout_marginBottom="24dp"
            android:progress="80"
            android:progressTint="#4FC3F7"
            android:progressBackgroundTint="#1A237E" />

        <TextView
            android:id="@+id/tvSpO2Status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="측정 대기 중"
            android:textColor="#90CAF9"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvSpO2Guide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="시작 버튼을 눌러 측정을 시작하세요."
            android:textColor="#546E7A"
            android:textSize="13sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="32dp"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button android:id="@+id/btnSpO2Start"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:layout_marginEnd="8dp" android:backgroundTint="#1565C0"
                android:text="측정 시작" android:textColor="#FFFFFF" android:stateListAnimator="@null"/>

            <Button android:id="@+id/btnSpO2Stop"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:backgroundTint="#B71C1C" android:text="측정 중지"
                android:textColor="#FFFFFF" android:enabled="false" android:stateListAnimator="@null"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/btnSpO2Back"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:layout_marginEnd="8dp" android:backgroundTint="#263238"
                android:text="돌아가기" android:textColor="#FFFFFF" android:stateListAnimator="@null"/>

            <Button android:id="@+id/btnSpO2Next"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:backgroundTint="#0D47A1" android:text="다음"
                android:textColor="#FFFFFF" android:stateListAnimator="@null"/>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
