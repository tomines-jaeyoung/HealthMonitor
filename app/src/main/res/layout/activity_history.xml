<?xml version="1.0" encoding="utf-8"?>
<!--
    달력/히스토리 레이아웃
    기술스택: AutoCompleteTextView (CompleteTextViewTest - 날짜 검색),
              TableLayout (날짜|수치|상태 3열), CheckBox (위험일 필터),
              TextView (Total 강조), CalendarView
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B3E"
    android:orientation="vertical">

    <!-- 상단 제목 -->
    <TextView
        android:id="@+id/tvHistoryTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:text="건강 데이터 추이"
        android:textColor="#4FC3F7"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- ============================================================
         AutoCompleteTextView: 날짜 검색 (CompleteTextViewTest)
         기술스택: AutoCompleteTextView
    ============================================================ -->
    <AutoCompleteTextView
        android:id="@+id/actSearchDate"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:hint="날짜 검색 (예: 2025-05)"
        android:textColorHint="#546E7A"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:background="@drawable/edit_text_bg"
        android:padding="12dp"
        android:completionThreshold="1"
        android:dropDownHeight="200dp"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:drawableEnd="@android:drawable/ic_menu_search"
        android:drawableTint="#4FC3F7" />

    <!-- 위험일 필터 체크박스 -->
    <LinearLayout
        android:id="@+id/layoutFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical">

        <CheckBox
            android:id="@+id/cbDangerFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="#EF5350"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="위험일만 보기"
            android:textColor="#EF5350"
            android:textSize="14sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Total 강조 텍스트 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total: "
            android:textColor="#90CAF9"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvTotalCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="28건"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- CalendarView -->
    <CalendarView
        android:id="@+id/calendarView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark" />

    <!-- ============================================================
         TableLayout: 날짜 | 수치 | 상태 3열 목록
         기술스택: TableLayout, CheckBox
    ============================================================ -->
    <ScrollView
        android:id="@+id/scrollTableHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp">

        <TableLayout
            android:id="@+id/tableHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="1">

            <!-- 헤더 행 -->
            <TableRow
                android:background="#1A237E"
                android:padding="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚑"
                    android:textColor="#90CAF9"
                    android:textSize="13sp"
                    android:padding="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="날짜"
                    android:textColor="#90CAF9"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="수치"
                    android:textColor="#90CAF9"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="상태"
                    android:textColor="#90CAF9"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="8dp" />

            </TableRow>

            <!-- 데이터 행 1 (정상) -->
            <TableRow android:id="@+id/row1" android:layout_marginTop="2dp">

                <CheckBox
                    android:id="@+id/cbRow1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#4FC3F7"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/tvDate1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="2026-05-16"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/tvValue1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="62 cm/s"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/tvStatus1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="정상"
                    android:textColor="#69F0AE"
                    android:textSize="13sp"
                    android:padding="8dp" />

            </TableRow>

            <!-- 데이터 행 2 (위험) -->
            <TableRow android:id="@+id/row2" android:layout_marginTop="2dp">

                <CheckBox
                    android:id="@+id/cbRow2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#EF5350"
                    android:checked="true"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/tvDate2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="2026-05-15"
                    android:textColor="#EF5350"
                    android:textSize="13sp"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/tvValue2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="38 cm/s"
                    android:textColor="#EF5350"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/tvStatus2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠ 위험"
                    android:textColor="#EF5350"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="8dp" />

            </TableRow>

            <TableRow android:id="@+id/row3" android:layout_marginTop="2dp">

                <CheckBox
                    android:id="@+id/cbRow3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#4FC3F7"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/tvDate3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="2026-05-14"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/tvValue3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="71 cm/s"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/tvStatus3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="정상"
                    android:textColor="#69F0AE"
                    android:textSize="13sp"
                    android:padding="8dp" />

            </TableRow>

            <TableRow android:id="@+id/row4" android:layout_marginTop="2dp">

                <CheckBox
                    android:id="@+id/cbRow4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#4FC3F7"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/tvDate4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="2026-05-13"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/tvValue4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="65 cm/s"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/tvStatus4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="정상"
                    android:textColor="#69F0AE"
                    android:textSize="13sp"
                    android:padding="8dp" />

            </TableRow>

        </TableLayout>

    </ScrollView>

    <!-- ============================================================
         전체측정 전용: 종합 건강 리포트 레이아웃 (기본값 gone)
         기술스택: ScrollView + LinearLayout
    ============================================================ -->
    <ScrollView
        android:id="@+id/scrollReport"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 리포트 카드 1: 혈류속도 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1A237E"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💉 혈류속도 리포트"
                    android:textColor="#4FC3F7"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvReportBloodFlow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="현재 혈류속도는 -- cm/s 이며 --가 권장됩니다."
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

            <!-- 리포트 카드 2: 심박수 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1A237E"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="❤️ 심박수 리포트"
                    android:textColor="#EF5350"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvReportHeartRate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="현재 심박수는 -- BPM 이며 --가 권장됩니다."
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

            <!-- 리포트 카드 3: 체온 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1A237E"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌡 체온 리포트"
                    android:textColor="#FFA726"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvReportTemp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="현재 체온은 -- °C 이며 --가 권장됩니다."
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

            <!-- 리포트 카드 4: 산소포화도 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1A237E"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💧 산소포화도 리포트"
                    android:textColor="#69F0AE"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvReportSpO2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="현재 산소포화도는 -- % 이며 --가 권장됩니다."
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- 하단 메인으로 버튼 -->
    <Button
        android:id="@+id/btnHistoryToMain"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="12dp"
        android:text="메인으로 돌아가기"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:backgroundTint="#1565C0" />

</LinearLayout>
